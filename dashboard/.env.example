# ── Discord OAuth2 ─────────────────────────────────────────────
# Create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret

# Must match exactly what you add in the OAuth2 Redirects list
DISCORD_REDIRECT_URI=https://dash.vigila.augystudios.com/api/auth/callback

# ── Discord Bot ─────────────────────────────────────────────────
# Same token the bot uses
DISCORD_BOT_TOKEN=your_bot_token

# ID of the Discord server this dashboard manages
DISCORD_GUILD_ID=your_guild_id

# Role ID required to access the dashboard (same as bot's STAFF_ROLE_ID)
STAFF_ROLE_ID=your_staff_role_id

# ── Database Paths ──────────────────────────────────────────────
# Paths relative to where you run the API from (dashboard/ directory)
WARNINGS_DB_PATH=../warnings.db
POLLS_DB_PATH=../staffpolls.db
TEMPLATES_DB_PATH=../polltemplates.db

# ── Supabase (for Auttaja integration) ─────────────────────────
# Leave blank if not using /auttaja commands
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Session ─────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret

# How many hours a login session lasts
JWT_EXPIRY_HOURS=24

# ── Server ──────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# Must match your actual domain
DASHBOARD_ORIGIN=https://dash.vigila.augystudios.com
