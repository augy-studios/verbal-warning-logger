# Discord bot token
DISCORD_TOKEN=your_token_here

# Where the bot logs add/edit/delete actions (channel ID)
LOG_CHANNEL_ID=123456789012345678

# Staff role ID. Anyone with this role OR any higher role can use /verbal commands.
STAFF_ROLE_ID=123456789012345678

# Embed colour (hex). Accepts 0x007FFF or 007FFF
EMBED_COLOR=0x007FFF

# Supabase project URL (Supabase dashboard → Project Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Supabase service-role key (Supabase dashboard → Project Settings → API → service_role)
# Keep this secret — it bypasses RLS. Only safe server-side.
SUPABASE_KEY=your_supabase_service_role_key_here
